# Copy to .env and fill in your values
# Used by docker-compose.yml and docker-compose.full.yml

# LLM / Embedding provider keys (set the ones you use)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Vector DB connection (defaults match the compose db service)
DB_CONNECTION_STRING=postgresql://docpipe:docpipe@db:5432/docpipe
DB_TABLE_NAME=documents

# Embedding settings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# LLM settings
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
